# Environment Configuration – copy to .env and fill in values
# -----------------------------------------------------------

# General
AGENT_ENV=development          # development | staging | production
LOG_LEVEL=INFO

# Kafka / Event Hub
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_CONSUMER_GROUP=threat-detection-agent
KAFKA_TELEMETRY_TOPIC=security.telemetry
KAFKA_ALERT_TOPIC=security.alerts

# Redis (dedup / checkpoint)
REDIS_URL=redis://localhost:6379/0

# PostgreSQL (checkpoint store)
POSTGRES_DSN=postgresql+asyncpg://agent:agent@localhost:5432/threat_detection

# SIEM Integration
SIEM_BASE_URL=https://siem.example.com/api
SIEM_API_KEY=

# EDR Integration
EDR_BASE_URL=https://edr.example.com/api
EDR_API_KEY=

# Ticketing (ServiceNow / Jira)
TICKETING_BASE_URL=https://tickets.example.com/api
TICKETING_API_KEY=

# Messaging (Teams / Slack)
MESSAGING_WEBHOOK_URL=

# Threat Intel Platform
THREAT_INTEL_BASE_URL=https://tip.example.com/api
THREAT_INTEL_API_KEY=

# CMDB / Asset Inventory
CMDB_BASE_URL=https://cmdb.example.com/api
CMDB_API_KEY=

# Anomaly Model Service
MODEL_INFERENCE_URL=http://localhost:8501/v1/models/anomaly:predict

# Monitoring
PROMETHEUS_PORT=9090
HEALTH_CHECK_PORT=8080
